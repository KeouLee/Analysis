&COLVAR
  &COMBINE_COLVAR
    &COLVAR 
      &DISTANCE
        POINTS 1 2
        &POINT 
          ATOMS 32
          TYPE GEO_CENTER
        &END POINT
        &POINT 
          ATOMS 494 508 433
          TYPE GEO_CENTER
        &END POINT
      &END DISTANCE
    &END COLVAR
    
    &COLVAR 
      &DISTANCE
        POINTS 1 2
        &POINT 
          ATOMS 67
          TYPE GEO_CENTER
        &END POINT
        &POINT 
          ATOMS 192 254 180
          TYPE GEO_CENTER
        &END POINT
      &END DISTANCE
    &END COLVAR
    
    &COLVAR
      &DISTANCE
        POINTS 1 2
        &POINT 
          ATOMS 32
          TYPE GEO_CENTER
        &END POINT
        &POINT 
          ATOMS  192 254 180
          TYPE GEO_CENTER
        &END POINT
      &END DISTANCE
    &END COLVAR

    &COLVAR
      &DISTANCE
        POINTS 1 2
        &POINT 
          ATOMS 67
          TYPE GEO_CENTER
        &END POINT
        &POINT 
          ATOMS 498 514 438
          TYPE GEO_CENTER
        &END POINT
      &END DISTANCE
    &END COLVAR
    FUNCTION d1+d2-d3-d4
    VARIABLES d1 d2 d3 d4
  &END COMBINE_COLVAR
&END COLVAR

! -----------------------
!           CV2          |
! -----------------------
&COLVAR
  &DISTANCE
    ATOMS 32 67
  &END DISTANCE
&END COLVAR

@INCLUDE 'subsys_colvar.inp'


&END SUBSYS
&END FORCE_EVAL
&MOTION
  &MD
    ENSEMBLE NVT
    STEPS  5000000
    TIMESTEP .5
    TEMPERATURE 300
    !TEMP_TOL   100
    &THERMOSTAT
      &NOSE
        LENGTH 3
        !YOSHIDA 3
        TIMECON 100.0
        !MTS 2
      &END NOSE
    &END
    !ANGVEL_ZERO
    !COMVEL_TOL  2.0E-7

    &PRINT
      &ENERGY
        &EACH
           MD 200
        &END
      &END

      &PROGRAM_RUN_INFO
        &EACH
           MD 1000
        &END
      &END
      FORCE_LAST
    &END PRINT
  &END MD

  &FREE_ENERGY
    &METADYN
      USE_PLUMED .FALSE.      
      WELL_TEMPERED .TRUE.
      DELTA_T 4500
      DO_HILLS 
      NT_HILLS 500
      WW 0.0008
      !TEMP_TOL  10.
      &METAVAR
        SCALE 1
        COLVAR 1
      &END METAVAR

      &METAVAR
        SCALE 10000
        COLVAR 2
        &WALL
          POSITION 9
          TYPE QUARTIC
          &QUARTIC
            DIRECTION WALL_PLUS
            K 150
          &END QUARTIC
        &END WALL
      &END METAVAR

@INCLUDE 'metadyn_metavar.inp'





      &PRINT
        &COLVAR
           COMMON_ITERATION_LEVELS 3
           &EACH
             MD 40
           &END
        &END COLVAR
        &HILLS
           COMMON_ITERATION_LEVELS 3
           &EACH
             MD 1
           &END
        &END
      &END
    &END METADYN
  &END

  &PRINT
    &TRAJECTORY
      FORMAT DCD
      &EACH
        MD 100
      &END
    &END
    &VELOCITIES OFF
    &END
    &RESTART
      &EACH
         MD 10000
      &END
      ADD_LAST NUMERIC
    &END
    &RESTART_HISTORY 
      &EACH
         MD 50000
      &END
    &END
  &END
&END MOTION

